---
layout: null
---
[
  {% assign searchable_pages = site.pages | where_exp: "item", "item.ext == '.html' and item.url != '/search.html'" | sort: "title" %}
  {% for item in searchable_pages %}
    {
      "title": {{ item.title | default: item.name | jsonify }},
      "url": {{ item.url | relative_url | jsonify }},
      "content": {{ item.content | strip_html | normalize_whitespace | jsonify }}
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
